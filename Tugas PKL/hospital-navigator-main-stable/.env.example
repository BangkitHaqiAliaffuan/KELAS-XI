# API Configuration
# For local development, use localhost
VITE_API_URL=http://localhost:3001/api/v1

# For production (Vercel), set this in Vercel Environment Variables:
# VITE_API_URL=https://your-backend-url.com/api/v1
# 
# Example production URLs:
# - Railway: https://your-app.railway.app/api/v1
# - Render: https://your-app.onrender.com/api/v1
# - Vercel: https://your-api.vercel.app/api/v1
#
# Note: If API is not available, the app will automatically fallback to static data
